{
  "name": "@moose-example/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "db:reset": "node --env-file=.env --import tsx prisma/reset.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@moose-example/database": "workspace:*",
    "@moose-example/temporal-client": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.4.18",
    "fastify": "^5.5.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
