    "pg": "^8.16.3",
    "@moose-example/database": "workspace:*",
    "@moose-example/temporal-client": "workspace:*",
    "@moose-example/temporal-worker": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
