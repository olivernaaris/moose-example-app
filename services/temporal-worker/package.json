{
  "name": "@moose-example/temporal-worker-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/worker.ts",
