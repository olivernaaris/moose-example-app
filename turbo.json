{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["src/**/generated/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", "src/**/generated/**"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["POSTHOG_PERSONAL_API_KEY", "POSTHOG_ENV_ID"]
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build", "^generate", "db:generate"]
    },
    "check": {
      "dependsOn": ["^build", "^generate", "generate", "db:generate"]
    },
    "test": {
      "dependsOn": ["^build", "^generate", "db:generate"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
